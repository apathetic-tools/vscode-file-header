{
  "name": "file-header-ai",
  "displayName": "File Header for AI, by Apathetic Tools",
  "version": "0.1.0",
  "description": "Lightweight file headers for AI chats and humans.",
  "keywords": [
    "file header",
    "comment header",
    "filepath",
    "filename",
    "AI chat",
    "context"
  ],
  "author": {
    "name": "Apathetic Tools",
    "url": "https://github.com/apathetic-tools"
  },
  "publisher": "apathetic",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/apathetic-tools/vscode-file-header"
  },
  "bugs": {
    "url": "https://github.com/apathetic-tools/vscode-file-header/issues"
  },
  "homepage": "https://github.com/apathetic-tools/vscode-file-header#readme",
  "type": "commonjs",
  "engines": {
    "node": ">=24",
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-file-header.insertHeader",
        "title": "File Header: Insert Header"
      },
      {
        "command": "vscode-file-header.updateHeader",
        "title": "File Header: Update Header"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".fileheader.json",
        "url": "./fileheader.schema.json"
      },
      {
        "fileMatch": ".fileheader.jsonc",
        "url": "./fileheader.schema.json"
      }
    ],
    "configuration": {
      "title": "File Header for AI",
      "properties": {
        "fileHeader.autoInsert": {
          "type": "boolean",
          "default": true,
          "description": "Automatically insert header on save if missing",
          "scope": "resource"
        },
        "fileHeader.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Replace an outdated header path when file moves",
          "scope": "resource"
        },
        "fileHeader.filePathStyle": {
          "type": "string",
          "enum": [
            "filename",
            "relativePath",
            "absolutePath"
          ],
          "default": "relativePath",
          "description": "What file path form to show in header",
          "scope": "resource"
        },
        "fileHeader.showLanguage": {
          "type": "boolean",
          "default": true,
          "description": "Show the main language label (from VSCode)",
          "scope": "resource"
        },
        "fileHeader.showFormat": {
          "type": "boolean",
          "default": true,
          "description": "Show format label (e.g. \"React\", \"GitHub Issue Template\")",
          "scope": "resource"
        },
        "fileHeader.showRoles": {
          "type": "boolean",
          "default": true,
          "description": "Show matching role labels (e.g., \"Page component\")",
          "scope": "resource"
        },
        "fileHeader.filePathTemplate": {
          "type": "string",
          "default": "${filePath}",
          "description": "Template to fill in the file path.",
          "scope": "resource"
        },
        "fileHeader.languageTemplate": {
          "type": "string",
          "default": " (${language})",
          "description": "Template for the language label.",
          "scope": "resource"
        },
        "fileHeader.formatTemplate": {
          "type": "string",
          "default": " (${format})",
          "description": "Template for the format label.",
          "scope": "resource"
        },
        "fileHeader.jointLanguageAndFormatTemplate": {
          "type": "string",
          "default": " (${language} — ${format})",
          "description": "Template for the combined language and format labels.",
          "scope": "resource"
        },
        "fileHeader.contextTemplate": {
          "type": "string",
          "default": " [${context}]",
          "description": "Template for the context label.",
          "scope": "resource"
        },
        "fileHeader.roleTemplate": {
          "type": "string",
          "default": " ${role}",
          "description": "Template for the role label.",
          "scope": "resource"
        },
        "fileHeader.useLanguagesById": {
          "type": "boolean",
          "default": true,
          "description": "Use VS Code language templates (keyed by languageId)",
          "scope": "resource"
        },
        "fileHeader.useLanguagesByPath": {
          "type": "boolean",
          "default": true,
          "description": "Use filepath-based language templates (keyed by glob patterns)",
          "scope": "resource"
        },
        "fileHeader.matchStyle": {
          "type": "string",
          "enum": [
            "filename",
            "relativePath",
            "absolutePath"
          ],
          "default": "relativePath",
          "description": "Match by this type of path",
          "scope": "resource"
        },
        "fileHeader.languagesById": {
          "type": "object",
          "description": "Language header templates keyed by VSCode language ID",
          "scope": "resource",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "headerTemplate": {
                "type": "string"
              },
              "matchStyle": {
                "type": "string",
                "enum": [
                  "filename",
                  "relativePath",
                  "absolutePath"
                ]
              },
              "language": {
                "type": "string"
              },
              "languageTemplate": {
                "type": "string"
              },
              "format": {
                "type": "string"
              },
              "formatTemplate": {
                "type": "string"
              },
              "jointLanguageAndFormatTemplate": {
                "type": "string"
              },
              "docs": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "note": {
                        "type": "string"
                      },
                      "url": {
                        "type": "string"
                      }
                    }
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "note": {
                          "type": "string"
                        },
                        "url": {
                          "type": "string"
                        }
                      }
                    }
                  }
                ]
              },
              "state": {
                "type": "string",
                "enum": [
                  "enabled",
                  "disabled",
                  "fallback"
                ]
              },
              "fileMatch": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "matchStyle": {
                        "type": "string",
                        "enum": [
                          "filename",
                          "relativePath",
                          "absolutePath"
                        ]
                      },
                      "glob": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "matchStyle": {
                                  "type": "string",
                                  "enum": [
                                    "filename",
                                    "relativePath",
                                    "absolutePath"
                                  ]
                                },
                                "glob": {
                                  "anyOf": [
                                    {
                                      "type": "string"
                                    },
                                    {
                                      "type": "array",
                                      "items": {
                                        "type": "string"
                                      }
                                    }
                                  ]
                                }
                              },
                              "required": [
                                "glob"
                              ]
                            }
                          }
                        ]
                      },
                      "language": {
                        "type": "string"
                      },
                      "languageTemplate": {
                        "type": "string"
                      },
                      "format": {
                        "type": "string"
                      },
                      "formatTemplate": {
                        "type": "string"
                      },
                      "jointLanguageAndFormatTemplate": {
                        "type": "string"
                      },
                      "context": {
                        "type": "string"
                      },
                      "contextTemplate": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "glob"
                    ]
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "matchStyle": {
                          "type": "string",
                          "enum": [
                            "filename",
                            "relativePath",
                            "absolutePath"
                          ]
                        },
                        "glob": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "matchStyle": {
                                    "type": "string",
                                    "enum": [
                                      "filename",
                                      "relativePath",
                                      "absolutePath"
                                    ]
                                  },
                                  "glob": {
                                    "anyOf": [
                                      {
                                        "type": "string"
                                      },
                                      {
                                        "type": "array",
                                        "items": {
                                          "type": "string"
                                        }
                                      }
                                    ]
                                  }
                                },
                                "required": [
                                  "glob"
                                ]
                              }
                            }
                          ]
                        },
                        "language": {
                          "type": "string"
                        },
                        "languageTemplate": {
                          "type": "string"
                        },
                        "format": {
                          "type": "string"
                        },
                        "formatTemplate": {
                          "type": "string"
                        },
                        "jointLanguageAndFormatTemplate": {
                          "type": "string"
                        },
                        "context": {
                          "type": "string"
                        },
                        "contextTemplate": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "glob"
                      ]
                    }
                  }
                ]
              }
            },
            "required": [
              "headerTemplate"
            ]
          }
        },
        "fileHeader.languagesByPath": {
          "type": "object",
          "default": {},
          "description": "Language header templates keyed by filename/glob",
          "scope": "resource",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "headerTemplate": {
                "type": "string"
              },
              "matchStyle": {
                "type": "string",
                "enum": [
                  "filename",
                  "relativePath",
                  "absolutePath"
                ]
              },
              "language": {
                "type": "string"
              },
              "languageTemplate": {
                "type": "string"
              },
              "format": {
                "type": "string"
              },
              "formatTemplate": {
                "type": "string"
              },
              "jointLanguageAndFormatTemplate": {
                "type": "string"
              },
              "docs": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "note": {
                        "type": "string"
                      },
                      "url": {
                        "type": "string"
                      }
                    }
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "note": {
                          "type": "string"
                        },
                        "url": {
                          "type": "string"
                        }
                      }
                    }
                  }
                ]
              },
              "state": {
                "type": "string",
                "enum": [
                  "enabled",
                  "disabled"
                ]
              },
              "fileMatch": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "matchStyle": {
                        "type": "string",
                        "enum": [
                          "filename",
                          "relativePath",
                          "absolutePath"
                        ]
                      },
                      "glob": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "matchStyle": {
                                  "type": "string",
                                  "enum": [
                                    "filename",
                                    "relativePath",
                                    "absolutePath"
                                  ]
                                },
                                "glob": {
                                  "anyOf": [
                                    {
                                      "type": "string"
                                    },
                                    {
                                      "type": "array",
                                      "items": {
                                        "type": "string"
                                      }
                                    }
                                  ]
                                }
                              },
                              "required": [
                                "glob"
                              ]
                            }
                          }
                        ]
                      },
                      "language": {
                        "type": "string"
                      },
                      "languageTemplate": {
                        "type": "string"
                      },
                      "format": {
                        "type": "string"
                      },
                      "formatTemplate": {
                        "type": "string"
                      },
                      "jointLanguageAndFormatTemplate": {
                        "type": "string"
                      },
                      "context": {
                        "type": "string"
                      },
                      "contextTemplate": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "glob"
                    ]
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "matchStyle": {
                          "type": "string",
                          "enum": [
                            "filename",
                            "relativePath",
                            "absolutePath"
                          ]
                        },
                        "glob": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "matchStyle": {
                                    "type": "string",
                                    "enum": [
                                      "filename",
                                      "relativePath",
                                      "absolutePath"
                                    ]
                                  },
                                  "glob": {
                                    "anyOf": [
                                      {
                                        "type": "string"
                                      },
                                      {
                                        "type": "array",
                                        "items": {
                                          "type": "string"
                                        }
                                      }
                                    ]
                                  }
                                },
                                "required": [
                                  "glob"
                                ]
                              }
                            }
                          ]
                        },
                        "language": {
                          "type": "string"
                        },
                        "languageTemplate": {
                          "type": "string"
                        },
                        "format": {
                          "type": "string"
                        },
                        "formatTemplate": {
                          "type": "string"
                        },
                        "jointLanguageAndFormatTemplate": {
                          "type": "string"
                        },
                        "context": {
                          "type": "string"
                        },
                        "contextTemplate": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "glob"
                      ]
                    }
                  }
                ]
              }
            },
            "required": [
              "headerTemplate",
              "fileMatch"
            ]
          }
        },
        "fileHeader.roles": {
          "type": "object",
          "default": {},
          "description": "Optional mapping of glob patterns to role/type labels. Example: { 'src/components/*': 'React component' }",
          "scope": "resource",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "state": {
                "type": "string",
                "enum": [
                  "enabled",
                  "disabled"
                ]
              },
              "matchStyle": {
                "type": "string",
                "enum": [
                  "filename",
                  "relativePath",
                  "absolutePath"
                ]
              },
              "glob": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "matchStyle": {
                          "type": "string",
                          "enum": [
                            "filename",
                            "relativePath",
                            "absolutePath"
                          ]
                        },
                        "glob": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            }
                          ]
                        }
                      },
                      "required": [
                        "glob"
                      ]
                    }
                  }
                ]
              },
              "role": {
                "type": "string"
              },
              "roleTemplate": {
                "type": "string"
              }
            },
            "required": [
              "glob",
              "role"
            ]
          }
        },
        "fileHeader.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Array of glob patterns (e.g. `src/**/*.ts`). If non-empty, only files matching these patterns will be processed.",
          "scope": "resource"
        },
        "fileHeader.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Array of glob patterns (e.g. `tests/**/*.test.ts`). Files matching these patterns will be skipped.",
          "scope": "resource"
        },
        "fileHeader.skipWords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "auto",
            "automatically",
            "generated"
          ],
          "description": "Array of words. If the first line of a file is a comment and contains any of these words, the file will be ignored.",
          "scope": "resource"
        },
        "fileHeader.insertAfterWords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "copyright",
            "license",
            "(c)",
            "©",
            "licensed"
          ],
          "description": "Array of words. If the first line of a file is a comment block containing any of these words, the header will be inserted after it.",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.build.json",
    "watch": "tsc -w -p tsconfig.build.json",
    "build": "pnpm run compile",
    "dev": "pnpm run watch",
    "package": "pnpm run build && vsce package",
    "publish": "pnpm run build && vsce publish",
    "icon:png": "pnpm run icon:png:128 && pnpm run icon:png:256",
    "icon:png:128": "pnpm dlx @resvg/resvg-js-cli images/icon.svg images/icon.png",
    "icon:png:256": "pnpm dlx @resvg/resvg-js-cli images/icon.svg images/icon@256.png 2",
    "format": "prettier --write .",
    "check": "pnpm run lint:prettier && pnpm run lint:eslint && pnpm run lint:tsc",
    "lint:prettier": "prettier --check .",
    "lint:eslint": "eslint \"{src,e2e,tests}/**/*.ts\"",
    "lint:tsc": "tsc --noEmit -p tsconfig.build.json",
    "fix": "pnpm run fix:prettier & pnpm run fix:eslint & pnpm run lint:tsc",
    "fix:prettier": "prettier --write .",
    "fix:eslint": "eslint \"{src,e2e,tests}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:e2e": "pnpm run build && tsc -p ./tsconfig.e2e.json && node .tsbuild/e2e/e2e/runTest.js",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "verify": "pnpm run lint:prettier & pnpm run lint:eslint & pnpm run lint:tsc & pnpm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "mocha": "^11.7.6",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.18.0",
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,.jsonc,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  }
}
